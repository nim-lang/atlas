version = "1.0.0"
packageName = "bin_metadata"
author = "Atlas Tester"
description = "Fixture for binary metadata parsing"
license = "MIT"
srcDir = "src"
binDir = "bin"
skipDirs = @["tests", "examples"]
skipFiles = @["config.local"]
skipExt = @["tmp", "bak"]
installDirs = @["assets"]
installFiles = @["README.md", "LICENSE"]
installExt = @["nim", "nims"]
bin = @["main", "worker"]
namedBin = {"main": "myfoo"}.toTable
namedBin["tools/helper"] = "helper"
backend = "c"
